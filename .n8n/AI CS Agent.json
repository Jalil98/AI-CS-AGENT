      "parameters": {
        "jsCode": "const hargaPerOunce = $json.rates?.IDR;\n\nif (!hargaPerOunce) {\n  return [{ error: \"Harga emas tidak tersedia\" }];\n}\n\nconst hargaPerGram = hargaPerOunce / 31.1035;\n\nconst gram = Number($node[\"output parser\"].json.value);\n\nif (isNaN(gram) || gram <= 0) {\n  return [{ error: \"Gram tidak valid\" }];\n}\n\nconst estimasi = hargaPerGram * gram;\n\nreturn [{\n  jenis_barang: \"emas\",\n  pertanyaan: `${gram} gram`,\n  harga_per_gram: Math.round(hargaPerGram),\n  estimasi: Math.round(estimasi)\n}];"
      },
