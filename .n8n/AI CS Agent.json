    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst chatId = $node[\"Telegram Trigger\"].json.message.chat.id.toString();\n\nconst session = staticData.sessions?.[chatId];\n\nif (!session) {\n  return [{\n    error: \"Session tidak ditemukan\"\n  }];\n}\n\nconst harga = session.harga_unit;\nconst wilayah = $json.value.toLowerCase();\n\nlet persen = 0.5;\n\nif (wilayah.includes(\"jawa barat\")) persen = 0.7;\nelse if (wilayah.includes(\"dki\")) persen = 0.8;\nelse if (wilayah.includes(\"jawa timur\")) persen = 0.6;\n\nconst estimasi = harga * persen;\n\nreturn [{\n  harga,\n  wilayah,\n  persen,\n  estimasi: Math.round(estimasi)\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        800,
        160
      ],
      "id": "549a0096-e25d-4168-a53f-113bd22489df",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\n\n// ambil harga dari Qdrant\nconst harga = $json.document.metadata.TAKSIRAN;\n\n// ambil chat id\nconst chatId = $node[\"Telegram Trigger\"].json.message.chat.id.toString();\n\n// buat container kalau belum ada\nif (!staticData.sessions) {\n  staticData.sessions = {};\n}\n\n// simpan harga berdasarkan chat id\nstaticData.sessions[chatId] = {\n  harga_unit: harga\n};\n\nreturn $json;"
      },
