ni-2.5-flash\"},\"response\":{\"response\":{\"generations\":[[{\"text\":\"{\\n  \\\"intent\\\": \\\"sapaan\\\",\\n  \\\"value\\\": \\\"Halo\\\"\\n}\",\"generationInfo\":{\"finishReason\":\"STOP\",\"index\":0}}]]},\"tokenUsage\":{\"completionTokens\":21,\"promptTokens\":379,\"totalTokens\":400}}}"}}
