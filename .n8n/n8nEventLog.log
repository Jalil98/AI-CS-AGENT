i-2.5-flash\"},\"response\":{\"response\":{\"generations\":[[{\"text\":\"{\\n  \\\"intent\\\": \\\"sebut_barang\\\",\\n  \\\"value\\\": \\\"Macbook pro\\\"\\n}\",\"generationInfo\":{\"finishReason\":\"STOP\",\"index\":0}}]]},\"tokenUsage\":{\"completionTokens\":24,\"promptTokens\":378,\"totalTokens\":402}}}"}}
