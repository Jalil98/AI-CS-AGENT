{"__type":"$$EventMessageAiNode","id":"fd1b60af-3bf6-4016-9f0a-6c68ae31cb86","ts":"2026-02-28T10:43:37.934-05:00","eventName":"n8n.ai.llm.generated","message":"n8n.ai.llm.generated","payload":{"executionId":"420","nodeName":"Google Gemini Chat Model","workflowName":"My workflow 2 copy","nodeType":"@n8n/n8n-nodes-langchain.lmChatGoogleGemini","workflowId":"lAvcNgIObhEc0qGA","msg":"{\"messages\":[\"System: Anda adalah AI intent classifier untuk sistem gadai.\\n\\nWAJIB mengembalikan JSON valid tanpa markdown dan tanpa teks tambahan.\\n\\nFormat wajib:\\n{\\n  \\\"intent\\\": \\\"nama_intent\\\",\\n  \\\"value\\\": \\\"isi_pesan_user\\\"\\n}\\n\\nJika user mengirim angka saja (contoh: 30),\\nmaka output harus:\\n\\n{\\n  \\\"intent\\\": \\\"input_gram\\\",\\n  \\\"value\\\": \\\"30\\\"\\n}\\n\\nIdentifikasi intent dari pesan user.\\n\\nKemungkinan intent:\\n- sapaan\\n- pilih_emas\\n- pilih_elektronik\\n- input_gram\\n- sebut_barang\\n- input_wilayah\\n\\nRules:\\n- Jika user bilang halo/hai → sapaan\\n- Jika user pilih emas → pilih_emas\\n- Jika user pilih elektronik → pilih_elektronik\\n- Jika user kirim angka → input_gram\\n- Jika user kirim nama barang → sebut_barang\\n- Jika user kirim nama wilayah → input_wilayah\\n\\nKembalikan JSON saja.\\nHuman: Halo\\nAI: {\\n  \\\"intent\\\": \\\"sapaan\\\",\\n  \\\"value\\\": \\\"Halo\\\"\\n}\\nHuman: Emas\\nAI: {\\n  \\\"intent\\\": \\\"pilih_emas\\\",\\n  \\\"value\\\": \\\"Emas\\\"\\n}\\nHuman: 10\\nAI: {\\n  \\\"intent\\\": \\\"input_gram\\\",\\n  \\\"value\\\": \\\"10\\\"\\n}\\nHuman: 10\\nAI: {\\n  \\\"intent\\\": \\\"input_gram\\\",\\n  \\\"value\\\": \\\"10\\\"\\n}\\nHuman: 10 gram\\nAI: {\\n  \\\"intent\\\": \\\"input_gram\\\",\\n  \\\"value\\\": \\\"10\\\"\\n}\\nHuman: Emas 30 gram\"],\"options\":{\"google_api_key\":{\"lc\":1,\"type\":\"secret\",\"id\":[\"GOOGLE_API_KEY\"]},\"base_url\":\"https://generativelanguage.googleapis.com\",\"model\":\"gemini-2.5-flash\"},\"response\":{\"response\":{\"generations\":[[{\"text\":\"{\\n  \\\"intent\\\": \\\"input_gram\\\",\\n  \\\"value\\\": \\\"30\\\"\\n}\",\"generationInfo\":{\"finishReason\":\"STOP\",\"index\":0}}]]},\"tokenUsage\":{\"completionTokens\":22,\"promptTokens\":365,\"totalTokens\":387}}}"}}
